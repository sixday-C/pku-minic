  .text
  .globl main
main:
  addi sp, sp, -32
entry:
  li t0, 2
  sw t0, 0(sp)
  lw t0, 0(sp)
  sw t0, 4(sp)

  lw t0, 4(sp)
  bnez t0, then_0
  j else_1
then_0:
  lw t0, 0(sp)
  sw t0, 8(sp)
  lw t0, 8(sp)
  li t1, 1
  add t0, t0, t1
  sw t0, 12(sp)
  lw t0, 12(sp)
  sw t0, 0(sp)
  j end_2
else_1:

  sw x0, 0(sp)
  j end_2
end_2:

  lw t0, 0(sp)
  sw t0, 16(sp)
  lw a0, 16(sp)
  addi sp, sp, 32
  ret
